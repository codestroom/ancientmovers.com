# Ancient Movers — Apache/LiteSpeed config for Hostinger
# Vite copies this file into dist/ on build, so it ends up in public_html.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve real files and folders directly. This means /api/*.php and
  # /admin/*.php run as normal PHP and are NOT rewritten to the SPA.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else falls back to the React single-page app.
  RewriteRule ^ index.html [L]
</IfModule>

# Don't cache index.html so new deploys are picked up immediately.
<IfModule mod_headers.c>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
